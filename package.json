{
  "name": "@mp-consulting/homebridge-philips-ambilight-tv",
  "displayName": "Philips Ambilight TV",
  "type": "module",
  "version": "1.3.7",
  "description": "Homebridge plugin to control Philips Ambilight TV as a HomeKit Television accessory.",
  "author": "Mickael Palma",
  "license": "(Apache-2.0 AND MIT)",
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/mickaelpalma"
  },
  "homepage": "https://github.com/mp-consulting/homebridge-philips-ambilight-tv#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mp-consulting/homebridge-philips-ambilight-tv.git"
  },
  "bugs": {
    "url": "https://github.com/mp-consulting/homebridge-philips-ambilight-tv/issues"
  },
  "keywords": [
    "ambilight",
    "android",
    "homebridge-plugin",
    "philips",
    "television",
    "tv"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "copy:ui-kit": "mkdir -p homebridge-ui/public/lib && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.css homebridge-ui/public/lib/ && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.js homebridge-ui/public/lib/",
    "build": "npm run copy:ui-kit && rimraf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "prepublishOnly": "npm test && npm run lint && npm run build",
    "watch": "npm run build && npm link && nodemon",
    "start": "npm run build && homebridge -U ./test/hbConfig -D -P .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:tv": "npm run build && node test/test-tv-endpoints.js"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.3",
    "bonjour-service": "^1.3.0",
    "class-validator": "^0.15.1",
    "node-arp": "^1.0.6",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mp-consulting/homebridge-ui-kit": "^1.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "homebridge": "^2.0.0-beta.55",
    "homebridge-config-ui-x": "^5.21.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json"
  ]
}
